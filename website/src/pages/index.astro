---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'EnviousWispr — Talk naturally. Paste perfectly.';
const description = 'Private AI dictation for macOS. Speak casually, get polished prose in any tone — on your device, never in the cloud. Free download.';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "EnviousWispr",
  "operatingSystem": "macOS",
  "applicationCategory": "UtilitiesApplication",
  "description": "Private AI dictation for macOS. On-device speech-to-text with AI polish. Your voice never leaves your Mac.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "Envious Labs" },
  "url": "https://enviouswispr.com/"
});
---

<BaseLayout title={title} description={description} activePage="home" canonicalPath="/">
  <Fragment slot="head">
    <meta name="keywords" content="private dictation mac, on-device speech to text, AI dictation macOS, voice to text privacy, offline dictation mac, macOS speech recognition, local transcription, macos dictation alternative, whisper mac app" />
    <script type="application/ld+json" set:html={jsonLd}></script>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════════
       Hero
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Hero">
    <div class="container">

      <!-- Animated lip SVG -->
      <div class="reveal" style="--i:0; text-align:center; margin-bottom:36px;">
        <svg class="hero-lips" style="width:160px;height:120px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" role="img" aria-label="EnviousWispr animated rainbow lip icon">
          <defs>
            <filter id="hero-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <g transform="translate(8,13)" filter="url(#hero-glow)" class="lip-glow-group">
            <rect class="upper-bar u0" x="16" y="84.2" width="14" height="20" rx="5" fill="#ff2a40" opacity="0.92"/>
            <rect class="upper-bar u1" x="40" y="65.75" width="14" height="32" rx="5" fill="#ff8c00" opacity="0.92"/>
            <rect class="upper-bar u2" x="64" y="43.36" width="14" height="48" rx="5" fill="#ffd700" opacity="0.92"/>
            <rect class="upper-bar u3" x="88" y="63.04" width="14" height="36" rx="5" fill="#adff2f" opacity="0.92"/>
            <rect class="upper-bar u4" x="112" y="81.43" width="14" height="24" rx="5" fill="#00fa9a" opacity="0.92"/>
            <rect class="upper-bar u5" x="136" y="63.04" width="14" height="36" rx="5" fill="#00ffff" opacity="0.92"/>
            <rect class="upper-bar u6" x="160" y="43.36" width="14" height="48" rx="5" fill="#1e90ff" opacity="0.92"/>
            <rect class="upper-bar u7" x="184" y="65.75" width="14" height="32" rx="5" fill="#4169e1" opacity="0.92"/>
            <rect class="upper-bar u8" x="208" y="84.2" width="14" height="20" rx="5" fill="#8a2be2" opacity="0.92"/>
            <rect class="lower-bar l0" x="16" y="125.8" width="14" height="20" rx="5" fill="#4169e1" opacity="0.88"/>
            <rect class="lower-bar l1" x="40" y="119.35" width="14" height="36" rx="5" fill="#1e90ff" opacity="0.88"/>
            <rect class="lower-bar l2" x="64" y="112.96" width="14" height="48" rx="5" fill="#00ffff" opacity="0.88"/>
            <rect class="lower-bar l3" x="88" y="120.64" width="14" height="60" rx="5" fill="#00fa9a" opacity="0.88"/>
            <rect class="lower-bar l4" x="112" y="127.03" width="14" height="68" rx="5" fill="#adff2f" opacity="0.88"/>
            <rect class="lower-bar l5" x="136" y="120.64" width="14" height="60" rx="5" fill="#ffd700" opacity="0.88"/>
            <rect class="lower-bar l6" x="160" y="112.96" width="14" height="48" rx="5" fill="#ff8c00" opacity="0.88"/>
            <rect class="lower-bar l7" x="184" y="119.35" width="14" height="36" rx="5" fill="#ff2a40" opacity="0.88"/>
            <rect class="lower-bar l8" x="208" y="125.8" width="14" height="20" rx="5" fill="#8a2be2" opacity="0.88"/>
          </g>
        </svg>
      </div>

      <h1 class="reveal" style="--i:1">Talk naturally.<br/>Paste perfectly.</h1>
      <p class="hero-sub reveal" style="--i:2">The fastest way to turn your voice into polished text on Mac. Private by design — your voice never leaves your device.</p>

      <div class="hero-ctas reveal" style="--i:3">
        <a href="https://github.com/saurabhav88/EnviousWispr/releases/latest/download/EnviousWispr.dmg" class="btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Free
        </a>
        <a href="/how-it-works/" class="btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="10 8 14 12 10 16"/></svg>
          See How It Works
        </a>
      </div>

      <div class="hero-trust reveal" style="--i:4">
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Free download</span>
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>No account needed</span>
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Works offline</span>
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>macOS 14+</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       One Voice. Any Tone. — STAR SECTION
       ═══════════════════════════════════════════════════════ -->
  <section class="tone-section section" id="tone-showcase" aria-labelledby="tone-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">AI Polish</div>
        <h2 class="section-title" id="tone-heading">One Voice. Any Tone.</h2>
        <p class="section-sub">Speak naturally. EnviousWispr polishes your words to match any context.</p>
      </div>

      <div class="tone-window reveal rainbow-glow" style="--i:1" id="toneWindow">
        <div class="tone-chrome" aria-hidden="true">
          <span class="chrome-dot red"></span>
          <span class="chrome-dot yellow"></span>
          <span class="chrome-dot green"></span>
          <span class="chrome-title">EnviousWispr — AI Polish</span>
        </div>
        <div class="tone-body">
          <!-- Raw voice input -->
          <div class="tone-input-label" aria-hidden="true">
            <span class="tone-mic-dot"></span>
            Raw Voice
          </div>
          <div class="tone-raw" role="region" aria-label="Raw voice input">
            <span class="open-quote" aria-hidden="true">"</span>
            So umm I wanted to like follow up on yesterday's meeting, basically the budget numbers need to be finalized before Friday I think, and also Sarah mentioned something about the Q3 projections being off
          </div>

          <!-- Divider arrow -->
          <div class="tone-divider" aria-hidden="true">
            <div class="tone-divider-line"></div>
            <div class="tone-divider-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="tone-divider-line"></div>
          </div>

          <!-- Tone toggle tabs -->
          <div class="tone-tabs" role="tablist" aria-label="Output tone">
            <button class="tone-tab active" data-tone="clean" role="tab" id="tone-tab-clean" aria-selected="true" aria-controls="tone-out-clean">Clean</button>
            <button class="tone-tab" data-tone="formal" role="tab" id="tone-tab-formal" aria-selected="false" aria-controls="tone-out-formal">Formal</button>
            <button class="tone-tab" data-tone="casual" role="tab" id="tone-tab-casual" aria-selected="false" aria-controls="tone-out-casual">Casual</button>
          </div>

          <!-- Output panels — instant swap with CSS fade, no typewriter -->
          <div class="tone-output-wrap" aria-live="polite">
            <div class="tone-output active" id="tone-out-clean" role="tabpanel" aria-labelledby="tone-tab-clean">
              <div class="tone-output-badge badge-clean">Clean</div>
              <div>I'm following up on yesterday's meeting. We need to finalize the budget numbers before Friday. Sarah also flagged that the Q3 projections may need revision.</div>
            </div>
            <div class="tone-output" id="tone-out-formal" role="tabpanel" aria-labelledby="tone-tab-formal">
              <div class="tone-output-badge badge-formal">Formal</div>
              <div>I am writing to follow up on our meeting yesterday. The budget figures require finalization by end of day Friday. Additionally, Sarah has raised concerns regarding the accuracy of the Q3 projections.</div>
            </div>
            <div class="tone-output" id="tone-out-casual" role="tabpanel" aria-labelledby="tone-tab-casual">
              <div class="tone-output-badge badge-casual">Casual</div>
              <div>Hey! Quick follow-up from yesterday — we gotta lock down those budget numbers before Friday. Oh and Sarah thinks the Q3 projections might be off.</div>
            </div>
          </div>

          <!-- Pasted indicator -->
          <div class="tone-pasted" aria-hidden="true">
            <span class="tone-pasted-dot"></span>
            Pasted &#10003;
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Scrolling App Marquee
       ═══════════════════════════════════════════════════════ -->
  <section class="marquee-section" aria-label="Compatible Apps">
    <p class="marquee-label">Works everywhere you type</p>
    <div class="marquee-track" role="presentation">
      <div class="marquee-row" id="marqueeRow" aria-hidden="true">
        <!-- Populated by JS -->
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Works Wherever You Write — Use Case Tabs
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="use-cases" aria-labelledby="usecases-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">Use Cases</div>
        <h2 class="section-title" id="usecases-heading">Works wherever<br/>you write.</h2>
        <p class="section-sub">From quick Slack replies to long-form documents — your voice, your tone, instantly polished.</p>
      </div>

      <div class="usecases-tabs reveal" style="--i:1" role="tablist" aria-label="Use case categories">
        <button class="tab-btn active" data-tab="emails" role="tab" id="tab-emails" aria-selected="true" aria-controls="panel-emails">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Emails
        </button>
        <button class="tab-btn" data-tab="slack" role="tab" id="tab-slack" aria-selected="false" aria-controls="panel-slack">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Slack &amp; Chat
        </button>
        <button class="tab-btn" data-tab="docs" role="tab" id="tab-docs" aria-selected="false" aria-controls="panel-docs">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Documents
        </button>
        <button class="tab-btn" data-tab="code" role="tab" id="tab-code" aria-selected="false" aria-controls="panel-code">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Code Comments
        </button>
        <button class="tab-btn" data-tab="notes" role="tab" id="tab-notes" aria-selected="false" aria-controls="panel-notes">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Notes
        </button>
      </div>

      <div class="tab-panel-wrap reveal" style="--i:2">

        <!-- Emails -->
        <div class="tab-panel active tab-emails" id="panel-emails" role="tabpanel" aria-labelledby="tab-emails">
          <div class="usecase-card">
            <div class="usecase-info">
              <div class="usecase-icon" aria-hidden="true">&#128231;</div>
              <h3>Emails</h3>
              <p>Draft replies in seconds. Your voice, your tone, automatically formatted. No more staring at the blank compose window.</p>
              <span class="usecase-tag">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Saves ~30 min/day
              </span>
            </div>
            <div class="usecase-preview">
              <div class="preview-mock">
                <div class="preview-mock-header">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  <span class="preview-mock-title">Re: Q3 Budget Review</span>
                </div>
                <div class="preview-mock-body">
                  <p>Hi Sarah,</p>
                  <p style="margin-top:6px;">Thanks for flagging this. I reviewed the Q3 projections and agree we need to finalize the budget numbers before Friday.</p>
                  <p style="margin-top:6px;">Can we schedule a sync tomorrow at 2pm?</p>
                  <p class="preview-success">&#10003; Drafted in 8 seconds</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Slack -->
        <div class="tab-panel tab-slack" id="panel-slack" role="tabpanel" aria-labelledby="tab-slack">
          <div class="usecase-card">
            <div class="usecase-info">
              <div class="usecase-icon" aria-hidden="true">&#128172;</div>
              <h3>Slack &amp; Chat</h3>
              <p>Quick messages without breaking your flow. Respond to threads in seconds — no more switching context to type.</p>
              <span class="usecase-tag">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Stay in the zone
              </span>
            </div>
            <div class="usecase-preview">
              <div class="preview-mock">
                <div class="preview-mock-header">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  <span class="preview-mock-title">#engineering</span>
                </div>
                <div class="preview-mock-body">
                  <p><span class="preview-name">you</span> <span class="preview-ts">just now</span></p>
                  <p style="margin-top:4px;">The deployment looks good on staging. I've verified all the edge cases we discussed. Ready to ship to prod when the team gives the green light.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Documents -->
        <div class="tab-panel tab-docs" id="panel-docs" role="tabpanel" aria-labelledby="tab-docs">
          <div class="usecase-card">
            <div class="usecase-info">
              <div class="usecase-icon" aria-hidden="true">&#128196;</div>
              <h3>Documents</h3>
              <p>Long-form writing at the speed of thought. Dictate a full paragraph, get structured prose. Ideal for reports, proposals, and specs.</p>
              <span class="usecase-tag">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Long-form in minutes
              </span>
            </div>
            <div class="usecase-preview">
              <div class="preview-mock">
                <div class="preview-mock-header">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                  <span class="preview-mock-title">Product Spec — Q4</span>
                </div>
                <div class="preview-mock-body">
                  <p><strong>Executive Summary</strong></p>
                  <p style="margin-top:6px;">This document outlines the proposed feature set for Q4. The primary objective is to improve retention by addressing the top three pain points identified in user research.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Code Comments -->
        <div class="tab-panel tab-code" id="panel-code" role="tabpanel" aria-labelledby="tab-code">
          <div class="usecase-card">
            <div class="usecase-info">
              <div class="usecase-icon" aria-hidden="true">&#128187;</div>
              <h3>Code Comments</h3>
              <p>Document your code by talking through it. Explain complex logic as you go — EnviousWispr formats it cleanly for code comments.</p>
              <span class="usecase-tag">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Better docs, naturally
              </span>
            </div>
            <div class="usecase-preview">
              <div class="code-preview" aria-label="Code example with dictated comment">
                <div class="code-preview-header">
                  <span class="chrome-dot red" aria-hidden="true"></span>
                  <span class="chrome-dot yellow" aria-hidden="true"></span>
                  <span class="chrome-dot green" aria-hidden="true"></span>
                </div>
                <div class="code-preview-body" aria-hidden="true">
                  <div class="code-comment">// Fetches the user's transcription history and filters</div>
                  <div class="code-comment">// out entries older than 30 days to reduce memory usage.</div>
                  <div class="code-comment">// Returns a sorted array, newest first.</div>
                  <div style="margin-top:6px;color:#f8f5ff;"><span class="code-keyword">func</span> <span class="code-fn">loadRecentHistory</span>() <span class="code-keyword">async throws</span> &#123;</div>
                  <div style="color:#f8f5ff;padding-left:16px;"><span class="code-keyword">let</span> cutoff = Date().addingTimeInterval(<span class="code-string">-2592000</span>)</div>
                  <div style="color:#f8f5ff;">&#125;</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Notes -->
        <div class="tab-panel tab-notes" id="panel-notes" role="tabpanel" aria-labelledby="tab-notes">
          <div class="usecase-card">
            <div class="usecase-info">
              <div class="usecase-icon" aria-hidden="true">&#128221;</div>
              <h3>Notes</h3>
              <p>Capture ideas before they disappear. Speak a stream of consciousness, get organized bullet points or a structured note.</p>
              <span class="usecase-tag">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Never lose an idea
              </span>
            </div>
            <div class="usecase-preview">
              <div class="preview-mock">
                <div class="preview-mock-header">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/></svg>
                  <span class="preview-mock-title">Meeting Notes — Monday</span>
                </div>
                <div class="preview-mock-body">
                  <p>&#8226; Finalize Q3 budget before Friday</p>
                  <p>&#8226; Sarah to review projection models</p>
                  <p>&#8226; Schedule follow-up sync for Wednesday</p>
                  <p>&#8226; Check in with design team on onboarding flow</p>
                  <p class="preview-meta">Captured in one take</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Two Ways to Dictate
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="modes" aria-labelledby="modes-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">Two Ways to Dictate</div>
        <h2 class="section-title" id="modes-heading">Pick the mode that<br/>fits the moment.</h2>
        <p class="section-sub">Whether you need a quick one-liner or a full email, there's a mode built for it.</p>
      </div>
      <div class="modes-grid reveal-stagger">
        <div class="mode-card push-card reveal" style="--i:0">
          <div class="mode-icon-wrap" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#e67e00" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </div>
          <span class="mode-tag">Push-to-Talk</span>
          <h3>Hold to record.<br/>Release to paste.</h3>
          <p>Perfect for quick messages, replies, and search queries. Hold your hotkey while you speak — the moment you release, polished text appears exactly where you're typing.</p>
          <div class="mode-hint">
            <div class="mode-hint-keys" aria-label="Keyboard shortcut: Right Command, hold">
              <span class="key-cap held" aria-hidden="true">&#8984;</span>
              <span class="key-sep" aria-hidden="true">— hold</span>
            </div>
            <span class="mode-hint-label">Hold Right Command while speaking, release to paste</span>
          </div>
        </div>
        <div class="mode-card hands-card reveal" style="--i:1">
          <div class="mode-icon-wrap" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#1e90ff" stroke-width="2" stroke-linecap="round"><path d="M2 12h2l3-9 4 18 4-18 3 9h2"/></svg>
          </div>
          <span class="mode-tag">Hands-Free</span>
          <h3>Double-press to start.<br/>Press once to stop.</h3>
          <p>Built for long-form writing — emails, documents, meeting notes. Double-press your hotkey to start recording, then press once to finish. Your hands stay free the whole time.</p>
          <div class="mode-hint">
            <div class="mode-hint-keys" aria-label="Keyboard shortcut: Right Command double-press">
