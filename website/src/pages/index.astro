---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'EnviousWispr: Free Private AI Dictation for macOS';
const description = 'On-device voice-to-text for macOS. Speak naturally, get polished prose in seconds. Powered by Apple Silicon, free to download, your audio never leaves your Mac.';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "EnviousWispr",
  "operatingSystem": "macOS 14+",
  "applicationCategory": "ProductivityApplication",
  "description": "Private AI dictation for macOS. On-device speech-to-text with AI polish. Your voice never leaves your Mac.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "downloadUrl": "https://github.com/saurabhav88/EnviousWispr/releases/latest/download/EnviousWispr.dmg",
  "image": "https://enviouswispr.com/og-image.png",
  "author": {
    "@type": "Organization",
    "name": "Envious Labs LLC",
    "url": "https://enviouslabs.co"
  },
  "url": "https://enviouswispr.com/"
});

const jsonLdOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Envious Labs",
  "legalName": "Envious Labs LLC",
  "url": "https://enviouslabs.co",
  "logo": "https://enviouswispr.com/favicon.svg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "9 High Plains Rd",
    "addressLocality": "Shelton",
    "addressRegion": "CT",
    "postalCode": "06484",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": "hello@enviouslabs.co",
    "url": "https://enviouswispr.com/contact/"
  },
  "founder": {
    "@type": "Person",
    "name": "Saurabh Vaish",
    "url": "https://enviouswispr.com/authors/saurabh-vaish/"
  },
  "sameAs": [
    "https://x.com/EnviousLabs",
    "https://www.youtube.com/@EnviousLabs",
    "https://www.linkedin.com/company/envious-labs/",
    "https://github.com/Envious-Labs-LLC",
    "https://github.com/saurabhav88/EnviousWispr"
  ]
});

const jsonLdPerson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Saurabh Vaish",
  "jobTitle": "Founder, Envious Labs",
  "url": "https://enviouswispr.com/authors/saurabh-vaish/",
  "worksFor": {
    "@type": "Organization",
    "name": "Envious Labs LLC",
    "url": "https://enviouslabs.co"
  },
  "sameAs": [
    "https://github.com/saurabhav88",
    "https://www.linkedin.com/in/saurabh-a-vaish-568253a6/",
    "https://x.com/EnviousLabs"
  ]
});

const jsonLdWebSite = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "EnviousWispr",
  "url": "https://enviouswispr.com/",
  "publisher": {
    "@type": "Organization",
    "name": "Envious Labs LLC",
    "url": "https://enviouslabs.co"
  }
});

const jsonLdFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is EnviousWispr free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. EnviousWispr is completely free to download and use. No subscription, no account required."
      }
    },
    {
      "@type": "Question",
      "name": "Does EnviousWispr work offline?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All speech recognition runs on-device using Apple Silicon. Your audio never leaves your Mac."
      }
    },
    {
      "@type": "Question",
      "name": "What makes EnviousWispr different from WisprFlow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EnviousWispr is free and processes everything on-device. WisprFlow costs $15/month and sends audio to cloud servers. EnviousWispr requires no account signup."
      }
    },
    {
      "@type": "Question",
      "name": "Which macOS versions does EnviousWispr support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EnviousWispr requires macOS 14 (Sonoma) or later running on Apple Silicon (M1 or newer)."
      }
    },
    {
      "@type": "Question",
      "name": "Does EnviousWispr support multiple languages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The default Parakeet engine handles English. The WhisperKit backend supports 90+ languages for multi-language dictation."
      }
    },
    {
      "@type": "Question",
      "name": "Can I see EnviousWispr's source code?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. EnviousWispr is open source under the GNU General Public License v3 (GPLv3), an OSI-approved license. The full codebase is on GitHub. You can read every line, build from source, and verify every privacy claim."
      }
    },
    {
      "@type": "Question",
      "name": "Which apps does EnviousWispr work with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EnviousWispr works with any app that accepts text input. It pastes directly into your active text field, whether that is Slack, VS Code, Gmail, Notion, Google Docs, Terminal, or any other app."
      }
    },
    {
      "@type": "Question",
      "name": "Does EnviousWispr run Whisper locally?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The WhisperKit backend runs OpenAI Whisper models locally via Apple Core ML. The default Parakeet engine uses NVIDIA's Parakeet TDT model, also running on-device. Both use Apple Silicon's Neural Engine for fast inference."
      }
    }
  ]
});
---

<BaseLayout title={title} description={description} activePage="home" canonicalPath="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd}></script>
    <script type="application/ld+json" set:html={jsonLdOrg}></script>
    <script type="application/ld+json" set:html={jsonLdPerson}></script>
    <script type="application/ld+json" set:html={jsonLdWebSite}></script>
    <script type="application/ld+json" set:html={jsonLdFaq}></script>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════════
       Hero
       ═══════════════════════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Hero">
    <div class="container">

      <!-- Animated lip SVG -->
      <div class="reveal" style="--i:0; text-align:center; margin-bottom:36px;">
        <svg class="hero-lips" style="width:160px;height:120px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" role="img" aria-label="EnviousWispr animated rainbow lip icon">
          <defs>
            <filter id="hero-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <g transform="translate(8,13)" filter="url(#hero-glow)" class="lip-glow-group">
            <rect class="upper-bar u0" x="16" y="84.2" width="14" height="20" rx="5" fill="#ff2a40" opacity="0.92"/>
            <rect class="upper-bar u1" x="40" y="65.75" width="14" height="32" rx="5" fill="#ff8c00" opacity="0.92"/>
            <rect class="upper-bar u2" x="64" y="43.36" width="14" height="48" rx="5" fill="#ffd700" opacity="0.92"/>
            <rect class="upper-bar u3" x="88" y="63.04" width="14" height="36" rx="5" fill="#adff2f" opacity="0.92"/>
            <rect class="upper-bar u4" x="112" y="81.43" width="14" height="24" rx="5" fill="#00fa9a" opacity="0.92"/>
            <rect class="upper-bar u5" x="136" y="63.04" width="14" height="36" rx="5" fill="#00ffff" opacity="0.92"/>
            <rect class="upper-bar u6" x="160" y="43.36" width="14" height="48" rx="5" fill="#1e90ff" opacity="0.92"/>
            <rect class="upper-bar u7" x="184" y="65.75" width="14" height="32" rx="5" fill="#4169e1" opacity="0.92"/>
            <rect class="upper-bar u8" x="208" y="84.2" width="14" height="20" rx="5" fill="#8a2be2" opacity="0.92"/>
            <rect class="lower-bar l0" x="16" y="125.8" width="14" height="20" rx="5" fill="#4169e1" opacity="0.88"/>
            <rect class="lower-bar l1" x="40" y="119.35" width="14" height="36" rx="5" fill="#1e90ff" opacity="0.88"/>
            <rect class="lower-bar l2" x="64" y="112.96" width="14" height="48" rx="5" fill="#00ffff" opacity="0.88"/>
            <rect class="lower-bar l3" x="88" y="120.64" width="14" height="60" rx="5" fill="#00fa9a" opacity="0.88"/>
            <rect class="lower-bar l4" x="112" y="127.03" width="14" height="68" rx="5" fill="#adff2f" opacity="0.88"/>
            <rect class="lower-bar l5" x="136" y="120.64" width="14" height="60" rx="5" fill="#ffd700" opacity="0.88"/>
            <rect class="lower-bar l6" x="160" y="112.96" width="14" height="48" rx="5" fill="#ff8c00" opacity="0.88"/>
            <rect class="lower-bar l7" x="184" y="119.35" width="14" height="36" rx="5" fill="#ff2a40" opacity="0.88"/>
            <rect class="lower-bar l8" x="208" y="125.8" width="14" height="20" rx="5" fill="#8a2be2" opacity="0.88"/>
          </g>
        </svg>
      </div>

      <h1>Talk naturally. <br/>Paste perfectly.</h1>
      <p class="hero-sub">Free private AI dictation for macOS. The fastest free, private way to turn your voice into polished text on Mac. On-device, on Apple Silicon, your voice never leaves your device.</p>

      <div class="hero-ctas reveal" style="--i:3">
        <a href="https://github.com/saurabhav88/EnviousWispr/releases/latest/download/EnviousWispr.dmg" class="btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Free
        </a>
        <a href="#how-it-works" class="btn-secondary" id="heroSeeHowBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="10 8 14 12 10 16"/></svg>
          See How It Works
        </a>
      </div>

      <p class="hero-req reveal" style="--i:3.5">Requires macOS Sonoma 14+ and Apple Silicon (M1 or later)</p>

      <div class="hero-trust reveal" style="--i:4">
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Free download</span>
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>No account needed</span>
        <span class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Works offline</span>
      </div>

      <p class="hero-brew reveal" style="--i:4.5">Prefer the terminal? <code>brew install --cask saurabhav88/tap/enviouswispr</code></p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       What EnviousWispr is — AI-citable definition
       ═══════════════════════════════════════════════════════ -->
  <section class="intro-def" aria-label="What EnviousWispr is">
    <div class="container">
      <p class="intro-def-text reveal">EnviousWispr is a free dictation app for macOS. Hold a hotkey, speak, and your words land as clean, polished text in whatever app you're using. Transcription runs entirely on your Mac, so your audio never leaves your device. Optional AI polish can tidy the text on-device too, or through a cloud provider you choose.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       How It Works — Video Demo
       ═══════════════════════════════════════════════════════ -->
  <section class="video-section section" id="how-it-works" aria-labelledby="video-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">How It Works</div>
        <h2 class="section-title" id="video-heading">See the 30-second workflow.</h2>
        <p class="section-sub">Hold a hotkey, speak naturally, and watch polished text land where you're typing.</p>
      </div>

      <div class="video-frame reveal rainbow-glow" style="--i:1">
        <div class="video-chrome" aria-hidden="true">
          <span class="chrome-dot red"></span>
          <span class="chrome-dot yellow"></span>
          <span class="chrome-dot green"></span>
          <span class="chrome-title">EnviousWispr Demo</span>
        </div>
        <div class="video-wrap" id="videoWrap" data-video-id="srS5OgTj3O4">
          <button class="video-poster" id="videoPoster" type="button" aria-label="Play EnviousWispr demo video">
            <img
              src="https://i.ytimg.com/vi/srS5OgTj3O4/maxresdefault.jpg"
              alt="EnviousWispr demo: voice to polished text on macOS"
              loading="lazy"
              width="1280"
              height="720"
            />
            <span class="video-play-btn" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Scrolling App Marquee
       ═══════════════════════════════════════════════════════ -->
  <section class="marquee-section" aria-label="Compatible Apps">
    <p class="marquee-label">Works everywhere you type</p>
    <div class="marquee-track" role="presentation">
      <div class="marquee-row" id="marqueeRow" aria-hidden="true">
        <!-- Populated by JS -->
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Use Cases — 3×3 grid linking to existing blog workflows
       ═══════════════════════════════════════════════════════ -->
  <section class="use-cases-section section" id="use-cases" aria-labelledby="usecases-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">Use Cases</div>
        <h2 class="section-title" id="usecases-heading">Nine ways people use<br/>EnviousWispr every day.</h2>
        <p class="section-sub">Pick the workflow that fits how you write.</p>
      </div>

      <div class="uc-grid reveal-stagger">
        <a href="/blog/dictation-for-developers-code-reviews/" class="uc-card tint-blue reveal" style="--i:0">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">💻</span>For Developers</span>
          <h3 class="uc-headline">Ship code without leaving flow.</h3>
          <p class="uc-tasks">PR descriptions, commit messages, code comments. Narrate while you work.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/dictation-for-writers-skip-blank-page/" class="uc-card reveal" style="--i:1">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">✍️</span>For Writers</span>
          <h3 class="uc-headline">Draft at the speed of thought.</h3>
          <p class="uc-tasks">First drafts, outlines, blog posts, essays. Beat the blank page by talking it out.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/meeting-notes-polished-summaries/" class="uc-card tint-purple reveal" style="--i:2">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">📊</span>For Founders &amp; Execs</span>
          <h3 class="uc-headline">Outpace your inbox.</h3>
          <p class="uc-tasks">Follow-ups, decisions, action items. Move at the speed of thinking.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/take-lecture-notes-by-speaking/" class="uc-card reveal" style="--i:3">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">🎓</span>For Students</span>
          <h3 class="uc-headline">Study smarter, write faster.</h3>
          <p class="uc-tasks">Lecture notes in real time. Essay outlines as you think. Research summaries.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/dictating-episode-scripts-without-losing-flow/" class="uc-card tint-cyan reveal" style="--i:4">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">🎙️</span>For Podcasters</span>
          <h3 class="uc-headline">From episode to show notes.</h3>
          <p class="uc-tasks">Episode descriptions, RSS notes, social clips. Capture while ideas are fresh.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/dictation-remote-workers-tired-of-typing/" class="uc-card reveal" style="--i:5">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">🏠</span>For Remote Workers</span>
          <h3 class="uc-headline">Stay responsive without breaking focus.</h3>
          <p class="uc-tasks">Slack replies, standups, ticket comments. No context switching.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/voice-input-rsi-keyboard-free-workflow/" class="uc-card tint-purple reveal" style="--i:6">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">♿</span>For Accessibility</span>
          <h3 class="uc-headline">Your voice, your primary input.</h3>
          <p class="uc-tasks">All-day continuous dictation. Hands-free, mode-switch-free, limit-free.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/dictation-parents-type-one-handed/" class="uc-card tint-blue reveal" style="--i:7">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">👶</span>For Parents</span>
          <h3 class="uc-headline">Dictate while your hands are full.</h3>
          <p class="uc-tasks">School emails, grocery lists, quick messages. Hands-on-the-baby friendly.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>

        <a href="/blog/dictation-for-healthcare-on-device-charting/" class="uc-card reveal" style="--i:8">
          <span class="uc-badge"><span class="uc-badge-icon" aria-hidden="true">🩺</span>For Healthcare</span>
          <h3 class="uc-headline">Chart notes without the keyboard.</h3>
          <p class="uc-tasks">Patient notes, referral letters, discharge summaries. Nothing leaves your Mac.</p>
          <span class="uc-cta">Read the workflow</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Two Ways to Dictate
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="modes" aria-labelledby="modes-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">Two Ways to Dictate</div>
        <h2 class="section-title" id="modes-heading">Pick the mode that<br/>fits the moment.</h2>
        <p class="section-sub">Whether you need a quick one-liner or a full email, there's a mode built for it.</p>
      </div>
      <div class="modes-grid reveal-stagger">
        <div class="mode-card push-card reveal" style="--i:0">
          <div class="mode-icon-wrap" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#e67e00" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </div>
          <span class="mode-tag">Push-to-Talk</span>
          <h3>Hold to record.<br/>Release to paste.</h3>
          <p>Perfect for quick messages, replies, and search queries. Hold your hotkey while you speak. The moment you release, polished text appears exactly where you're typing.</p>
          <div class="mode-hint">
            <div class="mode-hint-keys" role="img" aria-label="Keyboard shortcut: Right Command, hold">
              <span class="key-cap held" aria-hidden="true">&#8984;</span>
              <span class="key-sep" aria-hidden="true">· hold</span>
            </div>
            <span class="mode-hint-label">Hold Right Command while speaking, release to paste</span>
          </div>
        </div>
        <div class="mode-card hands-card reveal" style="--i:1">
          <div class="mode-icon-wrap" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#1e90ff" stroke-width="2" stroke-linecap="round"><path d="M2 12h2l3-9 4 18 4-18 3 9h2"/></svg>
          </div>
          <span class="mode-tag">Hands-Free</span>
          <h3>Double-press to start.<br/>Press once to stop.</h3>
          <p>Built for long-form writing: emails, documents, meeting notes. Double-press your hotkey to start recording, then press once to finish. Your hands stay free the whole time.</p>
          <div class="mode-hint">
            <div class="mode-hint-keys" role="img" aria-label="Keyboard shortcut: Right Command double-press">
              <span class="key-cap tap" aria-hidden="true">&#8984;</span>
              <span class="key-sep" aria-hidden="true">&#215;2</span>
            </div>
            <span class="mode-hint-label">Double-press Right Command to start, press once to stop</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       Benefits Grid
       ═══════════════════════════════════════════════════════ -->
  <section class="section" id="features" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-label-pill accent">Benefits</div>
        <h2 class="section-title" id="benefits-heading">Everything you need.<br/>Nothing you don't.</h2>
        <p class="section-sub">Built for people who think faster than they type.</p>
      </div>

      <div class="benefits-grid reveal-stagger">
        <div class="benefit-card reveal" style="--i:0">
          <div class="benefit-icon green" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00a868" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3>Private by Default</h3>
          <p>Your voice is processed entirely on your Mac. Nothing is uploaded. Nothing is stored. Not even by us. Speech recognition runs on Apple Silicon, not in the cloud.</p>
        </div>
        <div class="benefit-card reveal" style="--i:1">
          <div class="benefit-icon royal" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4169e1" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Works Everywhere</h3>
          <p>Dictate into any app: email, Slack, docs, notes, terminals. Text appears right where you're typing. Your previous clipboard is preserved.</p>
        </div>
