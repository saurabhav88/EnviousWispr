#!/bin/bash
# bd-safe v1 — from brain-seed spec 2026-03-08
set -euo pipefail

# bd-safe: Worktree safety wrapper for bd.
#
# Default (validation-only):
#   - Validates existing .beads/redirect; refuses if missing
#   - Enforces allowlist; blocks non-allowlisted commands
#   - Never creates, modifies, or heals any state
#
# In main repo: passes through to bd directly.

BD_REAL="$(command -v bd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [ -z "$REPO_ROOT" ]; then
    echo "bd-safe: ERROR: not inside a git repository" >&2
    exit 1
fi

MAIN_WORKTREE_GIT="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
MAIN_WORKTREE="$(cd "$MAIN_WORKTREE_GIT/.." 2>/dev/null && pwd)"

RESOLVED_REPO="$(cd "$REPO_ROOT" && pwd)"
RESOLVED_MAIN="$(cd "$MAIN_WORKTREE" && pwd)"
IS_WORKTREE=false
if [ "$RESOLVED_REPO" != "$RESOLVED_MAIN" ]; then
    IS_WORKTREE=true
fi

# --- Repo identity check ---
# This wrapper must only be invoked from the repo it belongs to.
# Verify the script file lives under the current repo's main worktree.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
case "$SCRIPT_DIR" in
    "$RESOLVED_MAIN"/*)
        ;; # Script lives in this repo — OK
    *)
        echo "bd-safe: ERROR: wrapper invoked from wrong repository." >&2
        echo "  wrapper belongs to: $(dirname "$SCRIPT_DIR")" >&2
        echo "  current repo:       $RESOLVED_MAIN" >&2
        exit 1
        ;;
esac

if [ "$IS_WORKTREE" = true ]; then
    MAIN_BEADS="$RESOLVED_MAIN/.beads"
    CMD="${1:-}"
    SUB="${2:-}"

    # --- Allowlist ---
    ALLOWED=false
    case "$CMD" in
        list|show|search|query|count|ready|blocked|\
        create|update|close|reopen|delete|dep|\
        comments|label|todo|set-state|state|children|\
        stale|lint|q|promote|defer|undefer|\
        status|stats|history|diff|graph|find-duplicates|orphans|\
        remember|recall|memories|forget|\
        prime|info|where|human|onboard|quickstart|preflight|\
        version|help|types|export|completion|\
        epic|swarm|gate|merge-slot|formula|cook|mol|\
        agent|audit|slot|duplicate|duplicates|supersede|\
        move|refile|mail)
            ALLOWED=true ;;
        doctor)
            # Allow doctor only without --fix
            for arg in "$@"; do
                if [ "$arg" = "--fix" ]; then
                    ALLOWED=false
                    break
                fi
            done
            [ "$ALLOWED" != false ] && ALLOWED=true
            ;;
        worktree)
            case "$SUB" in info|list) ALLOWED=true ;; esac ;;
        "")
            ALLOWED=true ;;
    esac

    if [ "$ALLOWED" = false ]; then
        echo "bd-safe: REFUSED '$CMD ${SUB:-}' from worktree." >&2
        echo "  Not on worktree allowlist. Run from main repo: $RESOLVED_MAIN" >&2
        exit 1
    fi

    # --- Redirect validation ---
    if [ ! -f "$REPO_ROOT/.beads/redirect" ]; then
        echo "bd-safe: ERROR: no .beads/redirect in this worktree." >&2
        echo "  Beads access requires a redirect to the main repo's .beads." >&2
        echo "  Set up redirect manually from the canonical main repo," >&2
        echo "  or use the documented Beads worktree flow for human-created worktrees." >&2
        exit 1
    fi

    # --- Validate redirect target ---
    REDIRECT_CONTENT="$(cat "$REPO_ROOT/.beads/redirect")"

    # Must resolve to a directory (bd resolves redirect relative to worktree root)
    RESOLVED_TARGET="$(cd "$REPO_ROOT" && cd "$REDIRECT_CONTENT" 2>/dev/null && pwd)" || true
    if [ -z "$RESOLVED_TARGET" ]; then
        echo "bd-safe: ERROR: .beads/redirect does not resolve." >&2
        echo "  content: '$REDIRECT_CONTENT'" >&2
        echo "  from: $REPO_ROOT/" >&2
        exit 1
    fi

    # Must resolve to the canonical main repo .beads (not any arbitrary .beads)
    if [ "$RESOLVED_TARGET" != "$MAIN_BEADS" ]; then
        echo "bd-safe: ERROR: .beads/redirect resolves to non-canonical target." >&2
        echo "  resolves to: $RESOLVED_TARGET" >&2
        echo "  expected:    $MAIN_BEADS" >&2
        exit 1
    fi

    # Target must contain metadata.json
    if [ ! -f "$RESOLVED_TARGET/metadata.json" ]; then
        echo "bd-safe: ERROR: redirect target missing metadata.json" >&2
        echo "  target: $RESOLVED_TARGET" >&2
        exit 1
    fi

    # Partial identity check: metadata.json dolt_database should match between
    # worktree and target. Note: worktree-local metadata may be stale or copied,
    # so this is a best-effort check, not definitive canonical proof. The primary
    # canonical validation is: redirect resolves to main repo .beads (checked above).
    if command -v python3 >/dev/null 2>&1; then
        TARGET_DB="$(python3 -c "import json; print(json.load(open('$RESOLVED_TARGET/metadata.json'))['dolt_database'])" 2>/dev/null || true)"
        WORKTREE_DB="$(python3 -c "import json; print(json.load(open('$REPO_ROOT/.beads/metadata.json'))['dolt_database'])" 2>/dev/null || true)"
        if [ -n "$TARGET_DB" ] && [ -n "$WORKTREE_DB" ] && [ "$TARGET_DB" != "$WORKTREE_DB" ]; then
            echo "bd-safe: ERROR: project identity mismatch." >&2
            echo "  redirect target DB: $TARGET_DB" >&2
            echo "  worktree expects:   $WORKTREE_DB" >&2
            exit 1
        fi
    fi
fi

exec "$BD_REAL" "$@"
