node_modules/
dist/
build/

# Screenshots and diagrams (local dev artifacts, not shipped)
# Ignore PNGs at root level (ad-hoc screenshots, diagrams)
/*.png

# Allow PNGs in tracked asset directories
# (Sources/Resources/ is auto-tracked)

# App bundle (build artifact)
EnviousWispr.app/

# appcast.xml is committed to main by CI (Sparkle reads it from raw GitHub URL)

# Models (large files, download at runtime — root-level only)
/Models/
*.mlmodel
*.mlpackage
*.gguf
*.bin
.me

# Sub-projects (separate git repos, nested inside EnviousWispr for tooling access)
EnviousType/

# Dolt database files (added by bd init)
.dolt/
*.db
.notebooklm/

# Local-only directories (not shipped, not needed for builds)
scripts/
docs/
content-engine/
