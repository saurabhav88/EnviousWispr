<script>
'use strict';

/* ═══════════════════════════════════════════════════════
   Pipeline Demo
   ═══════════════════════════════════════════════════════ */
var BAR_COUNT = 40;
var V2_COLORS = ['#ff2a40','#ff8c00','#ffd700','#adff2f','#00fa9a','#00ffff','#1e90ff','#4169e1','#8a2be2'];

var rawSegments = [
  { text: 'um ', filler: true },
  { text: 'so ' },
  { text: 'I I ', filler: true },
  { text: 'wanted to ' },
  { text: 'uh ', filler: true },
  { text: 'circle back on, on our Q3 planning, ' },
  { text: 'uh, ', filler: true },
  { text: 'discussion from ' },
  { text: 'like, ', filler: true },
  { text: 'last Tuesday... I think ' },
  { text: 'um ', filler: true },
  { text: 'the timeline is ' },
  { text: 'like ', filler: true },
  { text: 'realistic but we should ' },
  { text: 'uh ', filler: true },
  { text: 'probably add a buffer week for the ' },
  { text: 'um ', filler: true },
  { text: 'integration phase' }
];

var polishedStr = 'I wanted to circle back on our Q3 planning discussion from last Tuesday. I think the timeline is realistic, but we should probably add a buffer week for the integration phase.';
var polishedWords = polishedStr.split(' ');

var demoWrapper      = document.getElementById('demoWrapper');
var demoPanelLeft    = document.getElementById('demoPanelLeft');
var demoPipeline     = document.getElementById('demoPipeline');
var demoPanelRight   = document.getElementById('demoPanelRight');
var demoWaveform     = document.getElementById('demoWaveform');
var demoRawText      = document.getElementById('demoRawText');
var demoPolishedText = document.getElementById('demoPolishedText');
var demoAsrBadge     = document.getElementById('demoAsrBadge');
var demoSseBadge     = document.getElementById('demoSseBadge');
var demoReplayBtn    = document.getElementById('demoReplayBtn');
var gRecBar    = document.getElementById('gRecBar');
var gAsrBar    = document.getElementById('gAsrBar');
var gFinBar    = document.getElementById('gFinBar');
var gPreBar    = document.getElementById('gPreBar');
var gPolBar    = document.getElementById('gPolBar');
var gPasteBar  = document.getElementById('gPasteBar');
var gRecLabel  = document.getElementById('gRecLabel');
var gAsrLabel  = document.getElementById('gAsrLabel');
var gFinLabel  = document.getElementById('gFinLabel');
var gPreLabel  = document.getElementById('gPreLabel');
var gPolLabel  = document.getElementById('gPolLabel');
var gPasteLabel = document.getElementById('gPasteLabel');
var gOverlapBracket = document.getElementById('gOverlapBracket');
var gOverlapLabel   = document.getElementById('gOverlapLabel');
var gConcBadge = document.getElementById('gConcBadge');
var gConcText  = document.getElementById('gConcText');

var dTimers = [], dIntervals = [], dRafId = null;
function dLater(fn, ms) { var t = setTimeout(fn, ms); dTimers.push(t); return t; }
function dClearAll() {
  dTimers.forEach(clearTimeout); dIntervals.forEach(clearInterval);
  dTimers = []; dIntervals = [];
  if (dRafId) { cancelAnimationFrame(dRafId); dRafId = null; }
}

function createDemoBars() {
  while (demoWaveform.firstChild) demoWaveform.removeChild(demoWaveform.firstChild);
  for (var i = 0; i < BAR_COUNT; i++) {
    var bar = document.createElement('div');
    bar.className = 'bar';
    bar.style.background = V2_COLORS[i % V2_COLORS.length];
    bar.style.height = '8px';
    demoWaveform.appendChild(bar);
  }
}

var dWaveActive = false;
function tickDemoWave() {
  if (!dWaveActive) return;
  var bars = demoWaveform.children;
  var now = performance.now();
  for (var i = 0; i < bars.length; i++) {
    var phase = i * 0.35 + now * 0.004;
    var h = 8 + Math.abs(Math.sin(phase)) * 30 + Math.abs(Math.sin(phase * 0.7 + i)) * 10;
    bars[i].style.height = h + 'px';
  }
  dRafId = requestAnimationFrame(tickDemoWave);
}
function startDemoWave() { dWaveActive = true; tickDemoWave(); }
function stopDemoWave() {
  dWaveActive = false;
  if (dRafId) { cancelAnimationFrame(dRafId); dRafId = null; }
  var bars = demoWaveform.children;
  for (var i = 0; i < bars.length; i++) bars[i].style.height = '8px';
}

function animateGantt(bar, targetWidth, durMs, cb) {
  bar.classList.add('active');
  bar.style.transition = 'width ' + durMs + 'ms linear';
  requestAnimationFrame(function() { bar.style.width = targetWidth; });
  if (cb) dLater(cb, durMs);
}
function doneGantt(bar) { bar.classList.remove('active'); bar.classList.add('done'); }

function typeRaw(cb) {
  while (demoRawText.firstChild) demoRawText.removeChild(demoRawText.firstChild);
  var spans = [];
  rawSegments.forEach(function(seg) {
    var sp = document.createElement('span');
    if (seg.filler) sp.className = 'filler';
    demoRawText.appendChild(sp);
    spans.push({ el: sp, text: seg.text, pos: 0 });
  });
  var segIdx = 0;
  var totalChars = rawSegments.reduce(function(a, s) { return a + s.text.length; }, 0);
  var avgDelay = 4800 / (totalChars / 3);
  function tick() {
    if (segIdx >= spans.length) { if (cb) cb(); return; }
    var cur = spans[segIdx];
    var chunk = 2 + Math.floor(Math.random() * 3);
    var end = Math.min(cur.pos + chunk, cur.text.length);
    cur.el.textContent = cur.text.slice(0, end);
    cur.pos = end;
    if (cur.pos >= cur.text.length) segIdx++;
    if (segIdx < spans.length) {
      dLater(tick, avgDelay * (0.6 + Math.random() * 0.8));
    } else {
      if (cb) cb();
    }
  }
  tick();
}

function strikeFillers(cb) {
  var fillers = demoRawText.querySelectorAll('.filler');
  fillers.forEach(function(f, i) { dLater(function() { f.classList.add('struck'); }, i * 200); });
  dLater(cb, fillers.length * 200 + 200);
}

function streamPolished(cb) {
  demoPolishedText.textContent = '';
  var cursor = document.createElement('span');
  cursor.className = 'cursor-blink';
  demoPolishedText.appendChild(cursor);
  var wordIdx = 0;
  function emitBurst() {
    if (wordIdx >= polishedWords.length) {
      if (cursor.parentNode) cursor.parentNode.removeChild(cursor);
      if (cb) cb();
      return;
    }
    if (cursor.parentNode) cursor.parentNode.removeChild(cursor);
    var burstSize = 1 + Math.floor(Math.random() * 3);
    burstSize = Math.min(burstSize, polishedWords.length - wordIdx);
    for (var i = 0; i < burstSize; i++) {
      var ws = document.createElement('span');
      ws.className = 'sse-word';
      ws.textContent = (wordIdx > 0 ? ' ' : '') + polishedWords[wordIdx];
      demoPolishedText.appendChild(ws);
      (function(span, delay) { dLater(function() { span.classList.add('visible'); }, delay); })(ws, i * 30);
      wordIdx++;
    }
    demoPolishedText.appendChild(cursor);
    demoPolishedText.scrollTop = demoPolishedText.scrollHeight;
    var nextDelay = 40 + Math.random() * 60;
    if (Math.random() < 0.1) nextDelay += 60;
    dLater(emitBurst, nextDelay);
  }
  emitBurst();
}

function setConcBadge(text) { gConcText.textContent = text; gConcBadge.classList.add('visible'); }
function hideConcBadge() { gConcBadge.classList.remove('visible'); }

function resetDemo() {
  dClearAll();
  stopDemoWave();
  [demoPanelLeft, demoPipeline, demoPanelRight].forEach(function(e) { e.classList.remove('visible'); });
  demoPanelRight.classList.remove('glow-green');
  demoReplayBtn.classList.remove('visible');
  demoAsrBadge.classList.remove('active');
  demoSseBadge.classList.remove('active');
  hideConcBadge();
  [gRecBar, gAsrBar, gFinBar, gPreBar, gPolBar, gPasteBar].forEach(function(b) {
    b.style.transition = 'none';
    b.style.width = '0%';
    b.className = b.className.replace(/\s*(active|done)\b/g, '');
  });
  [gRecLabel, gAsrLabel, gFinLabel, gPreLabel, gPolLabel, gPasteLabel].forEach(function(l) { l.classList.remove('active'); });
  gOverlapBracket.classList.remove('visible');
  gOverlapLabel.classList.remove('visible');
  demoRawText.textContent = '';
  demoPolishedText.textContent = '';
  createDemoBars();
}

function runDemo() {
  resetDemo();

  dLater(function() { demoPanelLeft.classList.add('visible'); }, 100);
  dLater(function() { demoPipeline.classList.add('visible'); }, 400);
  dLater(function() { demoPanelRight.classList.add('visible'); }, 700);

  dLater(function() {
    startDemoWave();
    demoAsrBadge.classList.add('active');
    gRecLabel.classList.add('active');
    animateGantt(gRecBar, '100%', 5000);
    gAsrLabel.classList.add('active');
    animateGantt(gAsrBar, '100%', 5000);
    dLater(function() {
      gOverlapBracket.classList.add('visible');
      gOverlapLabel.classList.add('visible');
    }, 800);
    setConcBadge('Recording + ASR parallel');
    typeRaw(function() {});
  }, 1000);

  dLater(function() {
    stopDemoWave();
    demoAsrBadge.classList.remove('active');
    doneGantt(gRecBar); doneGantt(gAsrBar);
    gRecLabel.classList.remove('active'); gAsrLabel.classList.remove('active');
    gOverlapBracket.classList.remove('visible'); gOverlapLabel.classList.remove('visible');
    gFinLabel.classList.add('active');
    animateGantt(gFinBar, '15%', 500, function() { doneGantt(gFinBar); gFinLabel.classList.remove('active'); });
    gPreLabel.classList.add('active');
    animateGantt(gPreBar, '15%', 500, function() { doneGantt(gPreBar); gPreLabel.classList.remove('active'); });
    setConcBadge('Finalize + pre-warm concurrent');
    strikeFillers(function() {});
  }, 6000);

  dLater(function() {
    gPolLabel.classList.add('active');
    animateGantt(gPolBar, '100%', 1500, function() { doneGantt(gPolBar); gPolLabel.classList.remove('active'); });
    demoSseBadge.classList.add('active');
    setConcBadge('SSE tokens streaming');
    demoPanelRight.classList.add('glow-green');
    dLater(function() { streamPolished(function() { demoSseBadge.classList.remove('active'); }); }, 100);
  }, 7500);

  dLater(function() {
    gPasteLabel.classList.add('active');
    animateGantt(gPasteBar, '100%', 200, function() { doneGantt(gPasteBar); gPasteLabel.classList.remove('active'); });
    hideConcBadge();
  }, 9200);

  dLater(function() { demoReplayBtn.classList.add('visible'); }, 10000);
}

demoReplayBtn.addEventListener('click', function() { runDemo(); });

var demoPlayed = false;
var demoObserver = new IntersectionObserver(function(entries) {
  entries.forEach(function(entry) {
    if (entry.isIntersecting && !demoPlayed) {
      demoPlayed = true;
      runDemo();
    }
  });
}, { threshold: 0.3 });
demoObserver.observe(demoWrapper);

createDemoBars();
</script>

</BaseLayout>
