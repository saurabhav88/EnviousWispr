   109	        await withCheckedContinuation { continuation in
   110	          withObservationTracking {
   111	            _ = self.whisperKitSetup.setupState
   112	          } onChange: {
   113	            continuation.resume()
   114	          }
   115	        }
   116	      }
   117	    }
