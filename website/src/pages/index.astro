  box-shadow: 0 4px 14px rgba(124,58,237,0.28); flex-shrink: 0;
  font-size: 15px; color: #fff;
}

.tone-tabs {
  display: flex; gap: 8px; margin-bottom: 20px;
}
.tone-tab {
  padding: 9px 28px; border-radius: var(--radius-pill);
  border: 1.5px solid var(--border-hover); background: transparent;
  font-family: var(--font-body); font-size: 14px; font-weight: 600; color: var(--text-2);
  cursor: pointer; transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1);
}
.tone-tab:hover { border-color: rgba(124,58,237,0.25); color: var(--text); }
.tone-tab.active { color: #fff; border-color: transparent; box-shadow: 0 4px 16px rgba(124,58,237,0.3); }
.tone-tab[data-tone="clean"].active { background: linear-gradient(135deg, #7c3aed, #4169e1); }
.tone-tab[data-tone="formal"].active { background: linear-gradient(135deg, #1a1225, #4a3d60); }
.tone-tab[data-tone="casual"].active { background: linear-gradient(135deg, #ff8c00, #ff2a40); }

.tone-output-wrap { position: relative; min-height: 116px; }
.tone-output {
  background: var(--surface);
  border: 1.5px solid var(--border-hover);
  border-radius: var(--radius-card);
  padding: 22px 24px;
  font-size: 17px; font-weight: 500; line-height: 1.65; color: var(--text);
