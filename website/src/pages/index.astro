/* ═══════════════════════════════════════════════════════
   Marquee
   ═══════════════════════════════════════════════════════ */
.marquee-section { padding: 0 0 72px; position: relative; z-index: 1; overflow: hidden; }
.marquee-label { text-align: center; font-size: 13px; font-weight: 500; color: var(--text-3); margin-bottom: 24px; letter-spacing: 0.5px; }
