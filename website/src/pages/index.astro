</style>

<script>
'use strict';

/* ── Tone Tabs — instant swap with CSS fade ── */
const toneTabs    = document.querySelectorAll('.tone-tab');
const toneOutputs = document.querySelectorAll('.tone-output');

toneTabs.forEach(function(btn) {
  btn.addEventListener('click', function() {
    const target = btn.getAttribute('data-tone');

    toneTabs.forEach(function(b) {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    toneOutputs.forEach(function(o) { o.classList.remove('active'); });

    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const panel = document.getElementById('tone-out-' + target);
    if (panel) panel.classList.add('active');
  });
});

/* ── Marquee — safe DOM construction ── */
const APPS = [
  { name: 'Slack',      color: '#E01E5A' },
  { name: 'Gmail',      color: '#EA4335' },
  { name: 'VS Code',    color: '#007ACC' },
  { name: 'Notes',      color: '#FFD60A' },
  { name: 'Pages',      color: '#F05A30' },
  { name: 'Terminal',   color: '#00C880' },
  { name: 'Discord',    color: '#5865F2' },
  { name: 'Notion',     color: '#000000' },
  { name: 'Arc',        color: '#FF5A2D' },
  { name: 'Safari',     color: '#006FFF' },
  { name: 'Obsidian',   color: '#7C3AED' },
  { name: 'Linear',     color: '#5E6AD2' },
  { name: 'Figma',      color: '#F24E1E' },
  { name: 'Superhuman', color: '#EC4899' },
  { name: 'Bear',       color: '#D94F37' },
  { name: 'Craft',      color: '#1C1C1E' },
  { name: 'TextEdit',   color: '#4A3D60' },
  { name: 'Xcode',      color: '#147EFB' },
];

(function buildMarquee() {
  const row = document.getElementById('marqueeRow');
  if (!row) return;
  const items = APPS.concat(APPS).concat(APPS);
  items.forEach(function(app) {
    const chip = document.createElement('div');
    chip.className = 'app-chip';
    const dot = document.createElement('span');
    dot.className = 'chip-dot';
    dot.style.background = app.color;
    chip.appendChild(dot);
    chip.appendChild(document.createTextNode(app.name));
    row.appendChild(chip);
  });
})();

/* ── Use Case Tabs ── */
const tabBtns   = document.querySelectorAll('.tab-btn');
const tabPanels = document.querySelectorAll('.tab-panel');

tabBtns.forEach(function(btn) {
  btn.addEventListener('click', function() {
    const target = btn.getAttribute('data-tab');
    tabBtns.forEach(function(b) {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    tabPanels.forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const panel = document.getElementById('panel-' + target);
    if (panel) panel.classList.add('active');
  });
});
</script>
