  overflow: hidden;
  position: relative;
}
.tone-window::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--rainbow-full);
}
.tone-chrome {
  background: rgba(240,236,249,0.75);
