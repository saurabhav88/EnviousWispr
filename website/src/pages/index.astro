   ═══════════════════════════════════════════════════════ */
.video-section {
  padding: var(--section-pad) 0; position: relative; z-index: 1;
  scroll-margin-top: 80px;
}
.video-section::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent, rgba(124,58,237,0.03) 40%, rgba(0,255,255,0.02) 80%, transparent);
  pointer-events: none;
}

.video-frame {
  max-width: 980px; margin: 0 auto;
  background: #fff;
  border: 1px solid var(--border-hover);
  border-radius: 20px;
  box-shadow: 0 32px 96px rgba(124,58,237,0.12), 0 8px 24px rgba(0,0,0,0.06);
  overflow: hidden;
  position: relative;
}
.video-frame::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--rainbow-full); z-index: 2;
}
.video-chrome {
  background: rgba(240,236,249,0.75);
  padding: 12px 18px;
  display: flex; align-items: center; gap: 8px;
  border-bottom: 1px solid var(--border);
}
.chrome-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
.chrome-dot.red { background: #ff5f57; }
.chrome-dot.yellow { background: #febc2e; }
.chrome-dot.green { background: #28c840; }
.chrome-title {
  flex: 1; text-align: center;
  font-family: var(--font-mono); font-size: 12px; color: var(--text-3); font-weight: 500;
}

.video-wrap {
  position: relative; width: 100%; aspect-ratio: 16 / 9;
  background: #0f0a1a;
}
/* iframe is injected at runtime; scoped selector won't match without :global() */
.video-wrap :global(iframe) { width: 100%; height: 100%; border: 0; display: block; position: absolute; inset: 0; }
.video-poster {
  position: absolute; inset: 0; width: 100%; height: 100%;
  border: 0; padding: 0; cursor: pointer;
  background: #0f0a1a;
  display: block; overflow: hidden;
}
.video-poster img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.4s ease, opacity 0.2s ease;
}
.video-poster:hover img,
.video-poster:focus-visible img { transform: scale(1.02); opacity: 0.92; }
.video-poster:focus-visible { outline: 3px solid var(--accent); outline-offset: -3px; }
.video-play-btn {
