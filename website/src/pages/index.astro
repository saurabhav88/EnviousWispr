(function buildMarquee() {
  var row = document.getElementById('marqueeRow');
  if (!row) return;
  var items = APPS.concat(APPS).concat(APPS);
  items.forEach(function(app) {
    var chip = document.createElement('div');
    chip.className = 'app-chip';
    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('width', '20');
    svg.setAttribute('height', '20');
    svg.setAttribute('fill', app.color);
    svg.setAttribute('aria-hidden', 'true');
    var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', app.icon);
    svg.appendChild(path);
    chip.appendChild(svg);
    chip.appendChild(document.createTextNode(app.name));
    row.appendChild(chip);
  });
})();

/* ── Use Case Story Cards ── */
(function () {
  const track = document.getElementById('storyTrack');
  const dotsContainer = document.getElementById('ucProgressDots');
  const prevBtn = document.getElementById('ucPrevBtn');
  const nextBtn = document.getElementById('ucNextBtn');
  const cardCountEl = document.getElementById('ucCardCount');
  if (!track || !dotsContainer || !prevBtn || !nextBtn || !cardCountEl) return;

  const cards = Array.from(track.querySelectorAll('.uc-story-card'));
  const total = cards.length;
  let activeIndex = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragScrollLeft = 0;

  // Build dots
  cards.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'uc-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', 'Go to card ' + (i + 1));
    dot.addEventListener('click', () => scrollToCard(i));
    dotsContainer.appendChild(dot);
  });

  const dots = Array.from(dotsContainer.querySelectorAll('.uc-dot'));

  function setActive(index) {
    if (index < 0 || index >= total) return;
    activeIndex = index;
    dots.forEach((d, i) => d.classList.toggle('active', i === index));
    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === total - 1;
    cardCountEl.textContent = (index + 1) + ' / ' + total;
  }

  function scrollToCard(index) {
    const card = cards[index];
    const trackRect = track.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();
    const offset = cardRect.left - trackRect.left + track.scrollLeft;
    const padding = parseInt(getComputedStyle(track).paddingLeft) || 0;
    track.scrollTo({ left: offset - padding, behavior: 'smooth' });
  }

  // Scroll event for dot sync
  track.addEventListener('scroll', () => {
    const trackLeft = track.getBoundingClientRect().left;
    let closest = 0;
    let closestDist = Infinity;
    cards.forEach((card, i) => {
      const dist = Math.abs(card.getBoundingClientRect().left - trackLeft);
      if (dist < closestDist) { closestDist = dist; closest = i; }
    });
    if (closest !== activeIndex) setActive(closest);
  }, { passive: true });

  // Nav buttons
  prevBtn.addEventListener('click', () => scrollToCard(Math.max(0, activeIndex - 1)));
  nextBtn.addEventListener('click', () => scrollToCard(Math.min(total - 1, activeIndex + 1)));

  // Mouse drag support
  track.addEventListener('mousedown', (e) => {
    isDragging = true;
    dragStartX = e.pageX - track.offsetLeft;
    dragScrollLeft = track.scrollLeft;
    track.style.scrollSnapType = 'none';
  });

  track.addEventListener('mouseleave', endDrag);
  track.addEventListener('mouseup', endDrag);

  track.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    e.preventDefault();
    const x = e.pageX - track.offsetLeft;
    const walk = (x - dragStartX) * 1.2;
    track.scrollLeft = dragScrollLeft - walk;
  });

  function endDrag() {
    if (!isDragging) return;
    isDragging = false;
    track.style.scrollSnapType = '';
    const trackLeft = track.getBoundingClientRect().left;
    let closest = 0;
    let closestDist = Infinity;
    cards.forEach((card, i) => {
      const dist = Math.abs(card.getBoundingClientRect().left - trackLeft);
      if (dist < closestDist) { closestDist = dist; closest = i; }
    });
    scrollToCard(closest);
  }

  // Keyboard nav (scoped to when track is in viewport)
  document.addEventListener('keydown', (e) => {
    const rect = track.getBoundingClientRect();
    const inView = rect.top < window.innerHeight && rect.bottom > 0;
    if (!inView) return;
    if (e.key === 'ArrowLeft') scrollToCard(Math.max(0, activeIndex - 1));
    if (e.key === 'ArrowRight') scrollToCard(Math.min(total - 1, activeIndex + 1));
  });

  setActive(0);
})();
</script>
