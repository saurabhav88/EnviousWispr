---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog — EnviousWispr"
  description="Updates, release notes, and deep dives from the EnviousWispr team."
  activePage="blog"
>
  <section class="blog-page">
    <div class="container">

      <header class="blog-page-header reveal">
        <div class="section-label-pill accent">Blog</div>
        <h1 class="blog-page-title">From the team</h1>
        <p class="blog-page-sub">
          Updates, release notes, and deep dives on private AI dictation for macOS.
        </p>
      </header>

      {posts.length === 0 ? (
        <div class="blog-empty reveal">
          <p>No posts yet — check back soon.</p>
        </div>
      ) : (
        <ol class="blog-list" reversed>
          {posts.map((post, i) => (
            <li class="blog-card reveal" style={`--delay: ${i * 60}ms`}>
              <a href={`/blog/${post.id}/`} class="blog-card-link" aria-label={post.data.title}>
                <div class="blog-card-inner">
                  <div class="blog-card-meta">
                    <time datetime={post.data.pubDate.toISOString()} class="blog-card-date">
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags.length > 0 && (
                      <div class="blog-card-tags" role="list" aria-label="Tags">
                        {post.data.tags.slice(0, 3).map(tag => (
                          <span class="blog-card-tag" role="listitem">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>

                  <h2 class="blog-card-title">{post.data.title}</h2>
                  <p class="blog-card-desc">{post.data.description}</p>

                  <span class="blog-card-cta" aria-hidden="true">
                    Read post
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
                  </span>
                </div>
                <div class="blog-card-accent" aria-hidden="true"></div>
              </a>
            </li>
          ))}
        </ol>
      )}

    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding: 120px 0 96px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  .blog-page-header {
    max-width: 560px;
    margin-bottom: 64px;
  }

  .blog-page-title {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -2.5px;
    line-height: 1.08;
    color: var(--text);
    margin: 12px 0 16px;
  }

  .blog-page-sub {
    font-size: 18px;
    color: var(--text-2);
    line-height: 1.65;
  }

  /* Empty state */
  .blog-empty {
    text-align: center;
    padding: 80px 0;
    color: var(--text-3);
    font-size: 16px;
  }

  /* Post list */
  .blog-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 760px;
  }

  .blog-card {
    transition-delay: var(--delay, 0ms);
  }

  .blog-card-link {
    display: block;
    text-decoration: none;
    position: relative;
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .blog-card-link:hover {
    border-color: var(--border-hover);
    box-shadow: 0 8px 40px rgba(124, 58, 237, 0.10);
    transform: translateY(-2px);
  }

  .blog-card-link:hover .blog-card-accent {
    opacity: 1;
  }

  .blog-card-link:hover .blog-card-cta {
    color: var(--accent);
  }

  .blog-card-inner {
    padding: 28px 32px 24px;
    position: relative;
    z-index: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .blog-card-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.2px;
  }

  .blog-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .blog-card-tag {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(124, 58, 237, 0.15);
  }

  .blog-card-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.6px;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .blog-card-link:hover .blog-card-title {
    color: var(--accent);
  }

  .blog-card-desc {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .blog-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-3);
    transition: color 0.2s;
  }

  /* Rainbow accent bar along the bottom edge */
  .blog-card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--rainbow-full);
    opacity: 0;
    transition: opacity 0.3s;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .blog-page {
      padding: 100px 0 64px;
    }
    .blog-page-title {
      font-size: 36px;
      letter-spacing: -1.5px;
    }
    .blog-page-sub {
      font-size: 16px;
    }
    .blog-card-inner {
      padding: 22px 20px 18px;
    }
    .blog-card-title {
      font-size: 19px;
    }
  }
</style>
