  overflow: hidden;
  position: relative;
}
.tone-window::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--rainbow-full);
}
.tone-chrome {
  background: rgba(240,236,249,0.75);
  padding: 12px 18px;
  display: flex; align-items: center; gap: 8px;
  border-bottom: 1px solid var(--border);
}
.chrome-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
.chrome-dot.red { background: #ff5f57; }
.chrome-dot.yellow { background: #febc2e; }
.chrome-dot.green { background: #28c840; }
.chrome-title {
  flex: 1; text-align: center;
  font-family: var(--font-mono); font-size: 12px; color: var(--text-3); font-weight: 500;
}
.tone-body { padding: 32px 40px 36px; }

.tone-input-label {
